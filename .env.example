# =============================================================================
# Deployer credentials — pick ONE of MNEMONIC / DEPLOYER_PRIVATE_KEY
# =============================================================================
# For testnets the default Hardhat mnemonic works; for mainnet use a private
# key from a hardware-wallet-backed signer or a remote signer plugin.
MNEMONIC="test test test test test test test test test test test junk"
# DEPLOYER_PRIVATE_KEY=0xabc...

# =============================================================================
# RPC endpoints (Infura / Alchemy / QuickNode / self-hosted)
# =============================================================================
SEPOLIA_RPC_URL=
POLYGON_AMOY_RPC_URL=
POLYGON_RPC_URL=
MAINNET_RPC_URL=

# =============================================================================
# Block explorer verification (hardhat verify ...)
# =============================================================================
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=

# =============================================================================
# ENCL token wiring
# =============================================================================
# The canonical ENCL lives in the @enclaves/encl package. For a production
# deployment:
#   1. Deploy ENCL from the encl repo on the target network.
#   2. Copy its address from encl/deployments/<network>.json into ENCL_ADDRESS
#      here so the rwa deploy script binds StakingBond to the existing token.
# Leave ENCL_ADDRESS empty for local dev — the deploy script will then deploy
# a convenience ENCL bound to ENCL_TREASURY (1B initial supply, 18 decimals).
ENCL_ADDRESS=
ENCL_TREASURY=

# Initial ENCL/USD price (1e18-scaled). 1 ENCL = $0.25 -> 250000000000000000.
ENCL_PRICE_USD=250000000000000000
# Receiver of slashed ENCL.
ENCL_SLASH_RECEIVER=

# =============================================================================
# Per-Enclave wiring
# =============================================================================
# Platform backend (T-REX Agent role). Mints, sets mint conditions, runs
# yield distribution.
PLATFORM_AGENT=
# Identity Registry. Empty = deploy the MockIdentityRegistry (testnets only);
# set to the deployed ONCHAINID / T-REX IdentityRegistry on mainnet.
IR_ADDRESS=

# =============================================================================
# scripts/deploy-token.ts
# =============================================================================
# Path to the JSON config (see scripts/examples/example-biomass.json for a template).
TOKEN_CONFIG=scripts/examples/example-biomass.json
# Where deploy-token.ts / export-addresses.ts should write/append addresses.
DEPLOYMENTS=deployments/sepolia.json
# Optional override — when set, deploy-token.js uses this factory directly
# instead of reading it from DEPLOYMENTS.
FACTORY_ADDRESS=
